# Worker (Railway)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=sk-ant-...
EXA_API_KEY=your-exa-key
FIRECRAWL_API_KEY=fc-...
FAL_KEY=key:secret
GEMINI_API_KEY=your-gemini-api-key
# Image model: use 'gemini-2.0-flash-preview-image-generation' (default) or 'imagen-4.0-generate-001'
# WARNING: 'imagen-3.0-generate-002' is DEPRECATED and returns 404
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_TEXT_MODEL=gemini-2.5-pro
CLICKUP_API_TOKEN=pk_...
CLICKUP_ADVERTORIAL_LIST_ID=...
CLICKUP_CREATIVE_LIST_ID=...
VERCEL_TOKEN=...
VERCEL_TEAM_ID=team_...
REDIS_URL=redis://default:password@host:6379
API_SECRET=your-strong-secret-here

# Web (Vercel)
